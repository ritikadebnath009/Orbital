# OrbitalDEX Backend — copy to .env and fill in values

PORT=4000

STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# PostgreSQL
DATABASE_URL=postgresql://orbital:orbital@localhost:5432/orbital

# CORS — match your frontend URL
FRONTEND_URL=http://localhost:3000

# Token SAC addresses (testnet) — used only to resolve human-readable
# symbols for token_a/token_b when registering pools (db:seed and auto-discovery)
USDC_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
USDT_ADDRESS=CA7MHOQDFUHH5CZF66YFFONG6QT6SER7KO4PD7BLXBRF3KQTCECMQ34S
EURC_ADDRESS=CDZEYIBQSBSFED4F56EUGZB3LOFINAQETXODVFM4CACG4UY27WKHT5OE
XLM_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Pool addresses to index (comma-separated, filled by deploy_testnet.sh).
# Optional if FACTORY_ADDRESS is set — new pools are then auto-discovered.
POOL_ADDRESSES=

# PoolFactory contract address. When set, the backend watches its pool_new
# events and registers newly created pools automatically instead of
# requiring a manual POOL_ADDRESSES update + restart.
FACTORY_ADDRESS=
